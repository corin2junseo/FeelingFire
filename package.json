{
  "name": "feelingfire",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:smoke": "k6 run tests/smoke-test.js",
    "test:load": "k6 run tests/load-test.js",
    "test:stress": "k6 run tests/stress-test.js",
    "test:bench": "k6 run tests/perf/latency-benchmark.js",
    "test:bench:save": "k6 run --out json=tests/perf/results/after.json tests/perf/latency-benchmark.js",
    "test:smoke:save": "k6 run --out json=tests/perf/results/smoke.json tests/smoke-test.js",
    "test:load:save": "k6 run --out json=tests/perf/results/load.json tests/load-test.js",
    "report:compare": "node tests/perf/compare-report.mjs tests/perf/results/after.json",
    "report:chart": "node tests/perf/generate-chart.mjs tests/perf/results/after.json",
    "report:chart:smoke": "node tests/perf/generate-chart.mjs tests/perf/results/smoke.json",
    "report:chart:load": "node tests/perf/generate-chart.mjs tests/perf/results/load.json",
    "profile": "NODE_OPTIONS='--prof --prof-process' next dev",
    "profile:heap": "node --heap-prof --heap-prof-dir=.heap-profiles node_modules/.bin/next dev"
  },
  "dependencies": {
    "@polar-sh/sdk": "^0.45.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/fiber": "^9.5.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/three": "^0.183.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "replicate": "^1.4.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
